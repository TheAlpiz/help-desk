# ── Core ──────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/help-desk
NODE_ENV=development                 # development | test | production

# ── Auth / security ─────────────────────────────────────────────────────────────
# REQUIRED in production (no fallback). Generate: openssl rand -hex 64
JWT_SECRET=
APP_BASE_URL=http://localhost:5173
# Comma-separated browser origins allowed to send credentialed requests.
# Production example: https://app.alpis.app,https://admin.alpis.app
CORS_ORIGINS=http://localhost:5173
# Cookie scope. Empty = host-only. Set ".alpis.app" to share across subdomains.
COOKIE_DOMAIN=

# ── Redis ───────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── MinIO ───────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# ── Transactional email (auth flows: reset / verify / invite) ─────────────────────
# Leave SMTP_HOST empty in dev — auth emails are logged instead of sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@alpis.app

# ── GitHub App integration (optional; feature inert until set) ────────────────────
# Create a GitHub App, then fill these in. Token encryption reuses the key below.
GITHUB_APP_ID=
# PEM private key. Single-line form supported: replace real newlines with literal \n.
GITHUB_APP_PRIVATE_KEY=
# The app's URL slug (github.com/apps/<slug>) — used to build the install link.
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Webhook secret configured on the GitHub App; every delivery is HMAC-verified.
GITHUB_APP_WEBHOOK_SECRET=83b287ce7a165a7e4df23c313209b984c8c096526c0a549259ff9efb4145cab8
# Symmetric key for encrypting secrets at rest (mailbox passwords + GitHub tokens).
# REQUIRED in production. Must be stable across restarts / identical on every instance.
MAILBOX_ENCRYPTION_KEY=

# ── Observability (optional) ────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info
